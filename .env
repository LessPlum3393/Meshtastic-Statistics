# Meshtastic Map Configuration

# Fastest catch-up (map reports only): default is 0
MESHTASTIC_INCLUDE_LONGFAST=0

# Include all channels/presets (max traffic, fastest discovery): default is 0
# MESHTASTIC_INCLUDE_ALL_CHANNELS=1

# Data persistence (nodes + chart history): default is true
DATA_SAVE=true

# Database type: local (SQLite) or mongodb. Only one can be chosen at a time.
DATABASE_TYPE=local

# MongoDB connection string (used if DATABASE_TYPE=mongodb)
# MONGODB_URI=mongodb://localhost:27017/meshtastic

# Default local database file location (used if DATABASE_TYPE=local)
# MESHTASTIC_DB_PATH=meshtastic-data.db

# Hide/delete inactive nodes (in minutes): default is 1440 (24 hours)
NODE_INACTIVE=1440

# Enable/disable public API endpoints (/api/nodes, /api/stats, /api/history): default is true
API=true

# Server port: default is 3000
PORT=3000
